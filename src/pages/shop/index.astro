---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProductCard from '../../components/ProductCard.astro';
import ShopFilters from '../../components/shop/ShopFilters.astro';
import ShopToolbar from '../../components/shop/ShopToolbar.astro';
import ActiveFilterChips from '../../components/shop/ActiveFilterChips.astro';
import { products } from '../../data/products';
import { categories } from '../../data/categories';
import ShopProductTable from '../../components/shop/ShopProductTable.astro';
import {
  parseShopFilters,
  filterProducts,
  getCatalogMeta,
  countByCategory,
  countByBrand,
  getActiveFilterLabels,
  getDisplayPrice,
} from '../../lib/shop-filters';
import type { ShopExportRow } from '../../lib/shop-export';

const filters = parseShopFilters(Astro.url.searchParams);
const filtered = filterProducts(products, filters);
const meta = getCatalogMeta();

const facetBase = filterProducts(products, {
  ...filters,
  category: '',
  brands: [],
  onSale: false,
  inStock: false,
  newOnly: false,
  priceMin: null,
  priceMax: null,
});

const categoryCounts = countByCategory(facetBase);
const brandCounts = countByBrand(facetBase, filters.category || undefined);

const categoryName = categories.find((c) => c.slug === filters.category)?.name;
const activeChips = getActiveFilterLabels(filters, categoryName);

const categoryLabel = (slug: string) =>
  categories.find((c) => c.slug === slug)?.name ?? slug;

const exportRows: ShopExportRow[] = filtered.map((p) => ({
  SKU: p.sku,
  Nombre: p.name,
  Marca: p.brand,
  Categoría: categoryLabel(p.category),
  'Precio venta': getDisplayPrice(p),
  'Precio lista': p.price,
  Oferta: p.salePrice ? 'Sí' : 'No',
  Stock: p.inStock ? 'En stock' : 'Agotado',
  MPN: p.mpn,
  EAN: p.ean,
  URL: new URL(`/product/${p.slug}`, Astro.url.origin).href,
}));
---

<BaseLayout title="Tienda" description="Catálogo de repuestos con filtros avanzados">
  <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Tienda' }]} />

  <div class="flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Tienda</h1>
      <p class="mt-1 text-sm text-[var(--color-muted)]">
        Filtros por vehículo, categoría, marca, precio y disponibilidad.
      </p>
    </div>
  </div>

  <ActiveFilterChips chips={activeChips} />

  <div class="mt-8 flex flex-col gap-8 lg:flex-row lg:items-start">
    <div class="lg:w-72 shrink-0">
      <ShopFilters
        filters={filters}
        brands={meta.brands}
        brandCounts={brandCounts}
        categoryCounts={categoryCounts}
        catalogPriceMin={meta.priceMin}
        catalogPriceMax={meta.priceMax}
        resultCount={filtered.length}
        facetTotal={facetBase.length}
      />
    </div>

    <div class="min-w-0 flex-1">
      <ShopToolbar filters={filters} resultCount={filtered.length} />

      {
        filtered.length === 0 ? (
          <div class="mt-16 rounded-[var(--radius-md)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] p-12 text-center">
            <p class="text-lg font-medium">No hay productos con estos filtros</p>
            <p class="mt-2 text-sm text-[var(--color-muted)]">
              Prueba ampliar el rango de precio o quitar algún filtro.
            </p>
            <a
              href="/shop"
              class="mt-6 inline-block rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white"
            >
              Ver todo el catálogo
            </a>
          </div>
        ) : (
          <div id="shop-results" class="mt-6">
            <script
              type="application/json"
              id="shop-export-data"
              set:html={JSON.stringify(exportRows)}
            />
            <div id="shop-grid-view" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
              {filtered.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
            <div id="shop-table-view" class="hidden">
              <ShopProductTable products={filtered} />
            </div>
          </div>
        )
      }
    </div>
  </div>

  <script>
    import { initShopViewControls } from '../../lib/shop-view';
    initShopViewControls();
    document.addEventListener('astro:page-load', initShopViewControls);
  </script>
</BaseLayout>
