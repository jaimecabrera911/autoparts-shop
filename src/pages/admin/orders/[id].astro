---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import {
  adminOrders,
  getOrderById,
  orderStatusLabels,
  orderStatusColors,
  formatPrice,
} from '../../../data/admin-mock';

export function getStaticPaths() {
  return adminOrders.map((o) => ({ params: { id: o.id } }));
}

const { id } = Astro.params;
const order = getOrderById(id!);

if (!order) {
  return Astro.redirect('/admin/orders');
}
---

<AdminLayout title={`Pedido ${order.id}`}>
  <a href="/admin/orders" class="text-sm font-medium text-[var(--color-accent)]">← Pedidos</a>

  <div class="mt-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h2 class="text-xl font-semibold">{order.id}</h2>
      <p class="mt-1 text-sm text-[var(--color-muted)]">{order.date}</p>
    </div>
    <span
      class:list={[
        'rounded-full px-3 py-1 text-sm font-medium',
        orderStatusColors[order.status],
      ]}
    >
      {orderStatusLabels[order.status]}
    </span>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <section class="admin-card p-5">
      <h3 class="font-semibold">Cliente</h3>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-[var(--color-muted)]">Nombre</dt>
          <dd class="font-medium">{order.customer}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-[var(--color-muted)]">Email</dt>
          <dd>{order.email}</dd>
        </div>
      </dl>
    </section>

    <section class="admin-card p-5">
      <h3 class="font-semibold">Actualizar estado (demo)</h3>
      <select class="mt-4 w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm">
        {
          Object.entries(orderStatusLabels).map(([key, label]) => (
            <option value={key} selected={order.status === key}>
              {label}
            </option>
          ))
        }
      </select>
      <button
        type="button"
        class="mt-3 w-full rounded-lg bg-[var(--color-accent)] py-2 text-sm font-medium text-white"
      >
        Guardar cambios
      </button>
    </section>
  </div>

  <section class="admin-card mt-6 overflow-hidden">
    <div class="border-b border-[var(--color-border)] px-5 py-4">
      <h3 class="font-semibold">Líneas del pedido</h3>
    </div>
    <table class="admin-table w-full">
      <thead>
        <tr>
          <th class="px-5 py-3">Producto</th>
          <th class="px-5 py-3">SKU</th>
          <th class="px-5 py-3">Cant.</th>
          <th class="px-5 py-3 text-right">Precio</th>
          <th class="px-5 py-3 text-right">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {
          order.items.map((item) => (
            <tr>
              <td class="px-5 py-3">{item.name}</td>
              <td class="px-5 py-3 text-[var(--color-muted)]">{item.sku}</td>
              <td class="px-5 py-3 tabular-nums">{item.qty}</td>
              <td class="px-5 py-3 text-right tabular-nums">{formatPrice(item.price)}</td>
              <td class="px-5 py-3 text-right font-medium tabular-nums">
                {formatPrice(item.price * item.qty)}
              </td>
            </tr>
          ))
        }
      </tbody>
      <tfoot>
        <tr class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
          <td colspan="4" class="px-5 py-3 text-right font-semibold">
            Total
          </td>
          <td class="px-5 py-3 text-right text-lg font-semibold tabular-nums">
            {formatPrice(order.total)}
          </td>
        </tr>
      </tfoot>
    </table>
  </section>
</AdminLayout>
