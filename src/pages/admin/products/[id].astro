---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { products } from '../../../data/products';
import { formatPrice } from '../../../data/admin-mock';

export function getStaticPaths() {
  return products.map((p) => ({ params: { id: String(p.id) } }));
}

const { id } = Astro.params;
const product = products.find((p) => String(p.id) === id);

if (!product) {
  return Astro.redirect('/admin/products');
}
---

<AdminLayout title={`Editar · ${product.name}`}>
  <a href="/admin/products" class="text-sm font-medium text-[var(--color-accent)]">← Productos</a>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <section class="admin-card p-5">
        <h2 class="font-semibold">Información general</h2>
        <form class="mt-4 space-y-4">
          <label class="block text-sm">
            <span class="mb-1 block text-[var(--color-muted)]">Nombre</span>
            <input
              type="text"
              value={product.name}
              class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
            />
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm">
              <span class="mb-1 block text-[var(--color-muted)]">SKU</span>
              <input
                type="text"
                value={product.sku}
                class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
              />
            </label>
            <label class="block text-sm">
              <span class="mb-1 block text-[var(--color-muted)]">Slug</span>
              <input
                type="text"
                value={product.slug}
                class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
              />
            </label>
          </div>
          <label class="block text-sm">
            <span class="mb-1 block text-[var(--color-muted)]">Descripción</span>
            <textarea
              rows="4"
              class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
            >{product.description}</textarea>
          </label>
        </form>
      </section>

      <section class="admin-card p-5">
        <h2 class="font-semibold">Precio e inventario</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-3">
          <label class="block text-sm">
            <span class="mb-1 block text-[var(--color-muted)]">Precio</span>
            <input
              type="number"
              value={product.price}
              step="0.01"
              class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
            />
          </label>
          <label class="block text-sm">
            <span class="mb-1 block text-[var(--color-muted)]">Precio oferta</span>
            <input
              type="number"
              value={product.salePrice ?? ''}
              class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2"
            />
          </label>
          <label class="flex items-end gap-2 text-sm">
            <input type="checkbox" checked={product.inStock} class="rounded" />
            En stock
          </label>
        </div>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="admin-card p-5">
        <img
          src={product.image}
          alt={product.name}
          class="w-full rounded-lg object-cover aspect-square bg-gray-100"
        />
        <p class="mt-2 text-xs text-[var(--color-muted)]">Imagen desde catálogo demo</p>
      </section>

      <section class="admin-card p-5 text-sm">
        <h3 class="font-semibold">Metadatos</h3>
        <dl class="mt-3 space-y-2">
          <div class="flex justify-between">
            <dt class="text-[var(--color-muted)]">Marca</dt>
            <dd>{product.brand}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[var(--color-muted)]">Categoría</dt>
            <dd>{product.category}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[var(--color-muted)]">Precio actual</dt>
            <dd class="font-medium">{formatPrice(product.price)}</dd>
          </div>
        </dl>
        <a
          href={`/product/${product.slug}`}
          target="_blank"
          rel="noopener"
          class="mt-4 block text-center text-sm font-medium text-[var(--color-accent)]"
        >
          Ver en tienda ↗
        </a>
      </section>

      <button
        type="button"
        class="w-full rounded-lg bg-[var(--color-accent)] py-2.5 text-sm font-medium text-white"
      >
        Guardar (demo)
      </button>
    </aside>
  </div>
</AdminLayout>
