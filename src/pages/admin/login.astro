---
import '../../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Admin · Iniciar sesión</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-dvh items-center justify-center bg-[#f4f6f8] p-4 font-sans">
    <div class="w-full max-w-md rounded-xl border border-[#e5e7eb] bg-white p-8 shadow-sm">
      <p class="text-sm font-medium text-[#0f766e]">AutoParts Admin</p>
      <h1 class="mt-2 text-2xl font-semibold text-[#111827]">Iniciar sesión</h1>
      <p class="mt-2 text-sm text-[#6b7280]">
        Demo: usa cualquier email y contraseña <code class="rounded bg-gray-100 px-1">admin</code>
      </p>

      <form id="admin-login-form" class="mt-8 space-y-4">
        <label class="block text-sm">
          <span class="mb-1 block text-[#6b7280]">Email</span>
          <input
            type="email"
            name="email"
            required
            value="admin@autoparts.demo"
            class="w-full rounded-lg border border-[#e5e7eb] px-3 py-2.5 text-sm"
          />
        </label>
        <label class="block text-sm">
          <span class="mb-1 block text-[#6b7280]">Contraseña</span>
          <input
            type="password"
            name="password"
            required
            placeholder="admin"
            class="w-full rounded-lg border border-[#e5e7eb] px-3 py-2.5 text-sm"
          />
        </label>
        <p id="login-error" class="hidden text-sm text-red-600"></p>
        <button
          type="submit"
          class="w-full rounded-lg bg-[#0f766e] py-2.5 text-sm font-medium text-white hover:bg-[#0d9488]"
        >
          Entrar al panel
        </button>
      </form>

      <a href="/" class="mt-6 block text-center text-sm text-[#6b7280] hover:text-[#0f766e]">
        ← Volver a la tienda
      </a>
    </div>

    <script>
      if (sessionStorage.getItem('admin-auth') === 'demo') {
        window.location.href = '/admin';
      }

      document.getElementById('admin-login-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(e.target as HTMLFormElement);
        const pass = String(fd.get('password') ?? '');
        const err = document.getElementById('login-error');
        if (pass.length < 1) {
          if (err) {
            err.textContent = 'Introduce la contraseña.';
            err.classList.remove('hidden');
          }
          return;
        }
        sessionStorage.setItem('admin-auth', 'demo');
        window.location.href = '/admin';
      });
    </script>
  </body>
</html>
