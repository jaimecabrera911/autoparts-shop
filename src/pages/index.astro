---
import BaseLayout from '../layouts/BaseLayout.astro';
import VehicleFilter from '../components/VehicleFilter.astro';
import ProductCard from '../components/ProductCard.astro';
import Button from '../components/Button.astro';
import { categories } from '../data/categories';
import { products } from '../data/products';
---

<BaseLayout title="Inicio" description="Repuestos automotrices con búsqueda por vehículo y SKU">
  <section class="rounded-[var(--radius-md)] bg-[var(--color-surface)] border border-[var(--color-border)] p-8 md:p-12">
    <p class="text-sm font-medium text-[var(--color-accent)]">Catálogo inteligente</p>
    <h1 class="mt-2 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
      Encuentra la pieza correcta para tu vehículo
    </h1>
    <p class="mt-4 max-w-xl text-[var(--color-muted)]">
      Misma lógica que un ecommerce de autopartes profesional: compatibilidad, SKU técnico y compra
      en pocos pasos.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <Button href="/shop">Ver catálogo</Button>
      <Button href="/catalog" variant="secondary">Explorar por categoría</Button>
    </div>
  </section>

  <div class="mt-10">
    <VehicleFilter />
  </div>

  <section class="mt-14">
    <h2 class="text-xl font-semibold">Categorías</h2>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {
        categories.map((cat) => (
          <a
            href={`/shop?category=${cat.slug}`}
            class="flex flex-col items-center gap-2 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-center transition-colors hover:border-[var(--color-accent)]"
          >
            <span class="text-2xl text-[var(--color-accent)]" aria-hidden="true">
              {cat.icon}
            </span>
            <span class="text-sm font-medium">{cat.name}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-14">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-xl font-semibold">Destacados</h2>
      <a href="/shop" class="text-sm font-medium">Ver todos →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {products.filter((p) => p.salePrice || p.badge === 'new').slice(0, 4).map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>

  <section class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      [
        { title: 'Envío gratis', desc: 'Pedidos mayores a $25' },
        { title: 'Recogida en tienda', desc: 'Listo en 30 minutos' },
        { title: 'Compatibilidad', desc: 'Tabla por vehículo en cada pieza' },
        { title: 'Soporte técnico', desc: 'Chat y teléfono 8am–10pm' },
      ].map((item) => (
        <div class="rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <p class="font-medium">{item.title}</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">{item.desc}</p>
        </div>
      ))
    }
  </section>
</BaseLayout>
