---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const faqs = [
  {
    q: '¿Cómo busco por vehículo?',
    a: 'Usa el filtro YMME en la home o en la tienda. También puedes introducir el VIN.',
  },
  {
    q: '¿Cómo sé si una pieza es compatible?',
    a: 'En la ficha del producto verás la tabla de vehículos compatibles.',
  },
  {
    q: '¿Cuál es el costo de envío?',
    a: 'Envío estándar gratis en pedidos mayores a $25 (demo).',
  },
  {
    q: '¿Puedo devolver un producto?',
    a: 'Sí, dentro de 14 días en condición de reventa (política demo).',
  },
];
---

<BaseLayout title="FAQ" description="Preguntas frecuentes">
  <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'FAQ' }]} />
  <h1 class="text-2xl font-semibold">Preguntas frecuentes</h1>
  <dl class="mt-8 max-w-2xl space-y-6">
    {
      faqs.map((item) => (
        <div class="rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <dt class="font-medium">{item.q}</dt>
          <dd class="mt-2 text-sm text-[var(--color-muted)]">{item.a}</dd>
        </div>
      ))
    }
  </dl>
</BaseLayout>
