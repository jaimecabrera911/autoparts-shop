---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CatalogHub from '../../components/catalog/CatalogHub';
import { categories, vehicleMakes } from '../../data/categories';
import { getCatalogMeta } from '../../lib/shop-filters';
import { site } from '../../data/site';

const { brands } = getCatalogMeta();
---

<BaseLayout
  title="Catálogo"
  description={`Explora el catálogo de ${site.name} por vehículo, categoría o marca`}
>
  <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Catálogo' }]} />

  <CatalogHub client:load categories={categories} vehicleMakes={vehicleMakes} brands={brands} />
</BaseLayout>

<style is:global>
  .catalog-hub__intro {
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
</style>
