---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 md:grid-cols-4 md:px-6">
    <div>
      <p class="text-lg font-semibold">AutoParts</p>
      <p class="mt-2 text-sm text-[var(--color-muted)]">
        Repuestos automotrices. Demo Astro — diseño minimalista.
      </p>
    </div>
    <div>
      <p class="text-sm font-semibold">Catálogo</p>
      <ul class="mt-3 space-y-2 text-sm text-[var(--color-muted)]">
        <li><a href="/shop">Todas las piezas</a></li>
        <li><a href="/catalog">Por marca / categoría</a></li>
        <li><a href="/shop?on_sale=1">Promociones</a></li>
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold">Ayuda</p>
      <ul class="mt-3 space-y-2 text-sm text-[var(--color-muted)]">
        <li><a href="/faq">Preguntas frecuentes</a></li>
        <li><a href="/contact">Contacto</a></li>
        <li><a href="/my-account">Mi cuenta</a></li>
        <li><a href="/admin/login">Administración</a></li>
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold">Newsletter</p>
      <form class="mt-3 flex gap-2" onsubmit="return false;">
        <input
          type="email"
          placeholder="tu@email.com"
          class="min-w-0 flex-1 rounded-[var(--radius-sm)] border border-[var(--color-border)] px-3 py-2 text-sm"
        />
        <button
          type="submit"
          class="shrink-0 rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-4 py-2 text-sm font-medium text-white"
        >
          OK
        </button>
      </form>
    </div>
  </div>
  <div class="border-t border-[var(--color-border)] py-4 text-center text-xs text-[var(--color-muted)]">
    © {year} AutoParts Demo · Basado en especificación Mobex
  </div>
</footer>
