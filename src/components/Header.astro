---
const nav = [
  { href: '/catalog', label: 'Catálogo' },
  { href: '/shop', label: 'Tienda' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contacto' },
];
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur"
>
  <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 md:px-6">
    <a href="/" class="shrink-0 text-lg font-semibold tracking-tight text-[var(--color-text)]">
      Auto<span class="text-[var(--color-accent)]">Parts</span>
    </a>

    <form action="/shop" method="get" class="hidden flex-1 md:block" role="search">
      <label class="sr-only" for="header-search">Buscar pieza o SKU</label>
      <input
        id="header-search"
        type="search"
        name="q"
        placeholder="Buscar pieza o SKU…"
        class="w-full max-w-xl rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2 text-sm"
      />
    </form>

    <nav class="hidden items-center gap-6 text-sm font-medium lg:flex" aria-label="Principal">
      {nav.map((item) => <a href={item.href} class="text-[var(--color-text)] hover:text-[var(--color-accent)]">{item.label}</a>)}
    </nav>

    <div class="ml-auto flex items-center gap-2 md:gap-3">
      <a
        href="/my-account/garage"
        class="hidden rounded-[var(--radius-sm)] border border-[var(--color-border)] px-3 py-2 text-sm font-medium sm:inline-flex"
      >
        Mi garaje
      </a>
      <a
        href="/my-account/wishlist"
        class="rounded-[var(--radius-sm)] p-2 text-[var(--color-muted)] hover:bg-[var(--color-bg)]"
        aria-label="Wishlist"
      >
        ♡
      </a>
      <a
        href="/cart"
        class="relative flex items-center gap-1.5 rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-3 py-2 text-sm font-medium text-white hover:bg-[var(--color-accent-hover)]"
      >
        Carrito
        <span
          id="cart-count"
          class="min-w-[1.25rem] rounded-full bg-white/20 px-1.5 text-center text-xs tabular-nums"
          >0</span
        >
      </a>
    </div>
  </div>

  <nav class="flex gap-4 overflow-x-auto border-t border-[var(--color-border)] px-4 py-2 text-sm lg:hidden">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>

<script>
  import { getCartCount } from '../lib/cart';

  function updateBadge() {
    const el = document.getElementById('cart-count');
    if (el) el.textContent = String(getCartCount());
  }

  updateBadge();
  window.addEventListener('cart-updated', updateBadge);
  document.addEventListener('astro:page-load', updateBadge);
</script>
